---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const s = messages.intro;

const facts = [
  { icon: '⛩️', label: s.facts.type, value: s.facts.typeValue },
  { icon: '📍', label: s.facts.region, value: s.facts.regionValue },
  { icon: '⭐', label: s.facts.rating, value: s.facts.ratingValue },
  { icon: '🕕', label: s.facts.hours, value: s.facts.hoursValue },
];
---

<section class="section-padding" id="overview">
  <div class="container">
    <span class="eyebrow">{s.eyebrow}</span>
    <h2 class="section-title">{s.title}</h2>
    <p class="section-lead">{s.description}</p>

    <div class="fact-grid" style="margin-top:30px">
      {facts.map((f) => (
        <div class="fact-item">
          <div class="ico" style="font-size:1.4rem">{f.icon}</div>
          <h4>{f.label}</h4>
          <p>{f.value}</p>
        </div>
      ))}
    </div>

    <div class="intro-cols">
      <div class="card card-pad fade-up">
        <h3 class="block-title">{s.highlights.title}</h3>
        <ul class="list-check">
          {s.highlights.items.map((it: string) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{it}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="card card-pad guide fade-up">
        <span class="eyebrow" style="margin-bottom:8px">{s.guide.eyebrow}</span>
        <h3 class="block-title">{s.guide.title}</h3>
        <p class="guide-text">{s.guide.description}</p>
        <ul class="list-check">
          {s.guide.items.map((it: string) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{it}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 30px; }
  .block-title { font-size: 1.4rem; margin: 0 0 14px; }
  .guide { background: var(--green-soft); }
  .guide-text { color: var(--text-muted); margin: 0 0 14px; }
  @media (max-width: 820px) { .intro-cols { grid-template-columns: 1fr; } }
</style>
