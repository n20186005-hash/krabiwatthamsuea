---
import { getLangFromUrl, getI18n, languages, languagesList } from '../i18n/ui';
import { siteConfig } from '../config';

const lang = getLangFromUrl(Astro.url);
const { messages } = getI18n(Astro.url);
const nav = messages.header;
const t = messages.common;

const navLinks = [
  { href: `#overview`, label: nav.overview },
  { href: `#visit`, label: nav.visit },
  { href: `#transport`, label: nav.transport },
  { href: `#history`, label: nav.history },
  { href: `#gallery`, label: nav.gallery },
  { href: `#reviews`, label: nav.reviews },
  { href: `#faq`, label: nav.faq },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<header class="site-header" id="siteHeader">
  <div class="container header-inner">
    <a class="brand" href={`/${lang}`}>
      <span class="brand-mark">วัด</span>
      <span class="brand-text">{nav.siteName}</span>
    </a>

    <nav class="nav-desktop" aria-label="primary">
      {navLinks.map((l) => <a href={`/${lang}${l.href}`}>{l.label}</a>)}
    </nav>

    <div class="header-actions">
      <button id="themeToggle" class="icon-btn" aria-label={t.toggleTheme} title={t.toggleTheme}>
        <svg class="ico-sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="ico-moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <div class="lang-switch" role="group" aria-label={t.changeLanguage}>
        {languagesList.map((l) => (
          <a
            href={`/${l}${currentPath.replace(/^\/(zh|en|th)/, '')}`}
            class={`lang-opt${l === lang ? ' active' : ''}`}
          >{languages[l]}</a>
        ))}
      </div>

      <button id="menuToggle" class="icon-btn menu-toggle" aria-label="menu">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" id="navMobile" aria-label="mobile">
    {navLinks.map((l) => <a href={`/${lang}${l.href}`}>{l.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 18px;
    height: 68px;
  }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; }
  .brand-mark {
    display: grid; place-items: center;
    width: 38px; height: 38px;
    border-radius: 11px;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.1rem;
  }
  .brand-text { font-family: var(--font-display); font-size: 1.18rem; color: var(--heading); }

  .nav-desktop { display: flex; gap: 22px; margin-left: auto; }
  .nav-desktop a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 600;
    position: relative;
    padding: 4px 0;
    transition: color 0.2s ease;
  }
  .nav-desktop a:hover { color: var(--heading); }
  .nav-desktop a::after {
    content: '';
    position: absolute; left: 0; bottom: -2px;
    width: 0; height: 2px; background: var(--accent);
    transition: width 0.2s ease;
  }
  .nav-desktop a:hover::after { width: 100%; }

  .header-actions { display: flex; align-items: center; gap: 12px; }
  .icon-btn {
    width: 40px; height: 40px;
    border-radius: 11px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--heading);
    display: grid; place-items: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .icon-btn:hover { background: var(--surface-2); }
  .ico-moon { display: none; }
  :global(:root[data-theme='dark']) .ico-sun { display: none; }
  :global(:root[data-theme='dark']) .ico-moon { display: block; }

  .lang-switch {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    overflow: hidden;
    background: var(--surface);
  }
  .lang-opt {
    padding: 7px 13px;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--text-muted);
  }
  .lang-opt.active { background: var(--accent); color: #fff; }
  .lang-opt:hover:not(.active) { background: var(--surface-2); color: var(--heading); }

  .menu-toggle { display: none; }
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 8px 20px 16px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .nav-mobile a {
    padding: 12px 4px;
    color: var(--text);
    font-weight: 600;
    border-bottom: 1px solid var(--border);
  }
  .nav-mobile a:last-child { border-bottom: 0; }

  @media (max-width: 920px) {
    .nav-desktop { display: none; }
    .menu-toggle { display: grid; }
    .nav-mobile.open { display: flex; }
  }
  @media (min-width: 921px) {
    .nav-mobile { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById('themeToggle');
    if (toggle) {
      toggle.addEventListener('click', function () {
        var root = document.documentElement;
        var isDark = root.getAttribute('data-theme') === 'dark';
        if (isDark) { root.removeAttribute('data-theme'); localStorage.setItem('theme', 'light'); }
        else { root.setAttribute('data-theme', 'dark'); localStorage.setItem('theme', 'dark'); }
      });
    }
    var menu = document.getElementById('menuToggle');
    var nav = document.getElementById('navMobile');
    if (menu && nav) {
      menu.addEventListener('click', function () { nav.classList.toggle('open'); });
      nav.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { nav.classList.remove('open'); });
      });
    }
  })();
</script>
