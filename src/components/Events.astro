---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const e = messages.events;
---

<section class="section-padding" id="events" style="background:var(--surface)">
  <div class="container">
    <span class="eyebrow">{e.eyebrow}</span>
    <h2 class="section-title">{e.title}</h2>
    <p class="section-lead">{e.subtitle}</p>

    <div class="events-list">
      {e.festivals.map((fest: any) => (
        <article class="card card-pad event fade-up">
          <div class="event-header">
            <h3 class="event-title">{fest.name}</h3>
            <span class="event-time">{fest.time}</span>
          </div>
          <p class="event-desc">{fest.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .events-list {
    display: grid;
    gap: 20px;
    margin-top: 30px;
  }
  .event {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .event-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  .event-title {
    font-size: 1.25rem;
    margin: 0;
    color: var(--heading);
  }
  .event-time {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-soft);
    padding: 4px 12px;
    border-radius: 20px;
  }
  .event-desc {
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>
