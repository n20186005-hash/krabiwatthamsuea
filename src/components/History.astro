---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const h = messages.history;
---

<section class="section-padding" id="history" style="background:var(--surface-accent)">
  <div class="container">
    <span class="eyebrow">{h.eyebrow}</span>
    <h2 class="section-title">{h.title}</h2>
    <p class="section-lead">{h.subtitle}</p>

    <div class="history-list">
      {h.sections.map((sec: any) => (
        <article class="card card-pad hist fade-up">
          <div class="hist-no">{sec.no}</div>
          <div>
            <h3 class="hist-title">{sec.title}</h3>
            <p class="hist-text">{sec.content}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mission-block legend-callout">
      <p class="mission-title">{h.legendTitle}</p>
      <p class="mission-text">{h.legendText}</p>
    </div>
  </div>
</section>

<style>
  .history-list { display: grid; gap: 18px; margin-top: 30px; }
  .hist { display: flex; gap: 20px; align-items: flex-start; }
  .hist-no {
    flex: none; width: 46px; height: 46px; border-radius: 12px;
    background: var(--accent); color: #fff; display: grid; place-items: center;
    font-family: var(--font-display); font-weight: 700; font-size: 1.3rem;
  }
  .hist-title { font-size: 1.3rem; margin: 4px 0 8px; }
  .hist-text { color: var(--text-muted); margin: 0; }
  .legend-callout { background: var(--surface); border-color: var(--border-strong); }
  @media (max-width: 620px) { .hist { flex-direction: column; gap: 12px; } }
</style>
