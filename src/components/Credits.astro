---
import { getI18n } from '../i18n/ui';
import attrib from '../data/photo-attributions.json';

const { messages } = getI18n(Astro.url);
const c = messages.credits;
---

<section class="section-padding" id="credits" style="background:var(--surface)">
  <div class="container">
    <span class="eyebrow">{c.eyebrow}</span>
    <h2 class="section-title">{c.title}</h2>
    <p class="section-lead">{c.subtitle}</p>

    <ul class="credits-grid">
      {attrib.map((a, i) => (
        <li class="credit-card">
          <img src={`/gallery/${a.file}`} alt={a.file} loading="lazy" width="120" height="80" />
          <div class="credit-body">
            <span class="credit-no">{String(i + 1).padStart(2, '0')}</span>
            <a class="credit-link" href={a.flickr} target="_blank" rel="noopener">{c.sourceLabel}</a>
            <span class="credit-tags">{c.tagsLabel}: {a.tags}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .credits-grid {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .credit-card {
    display: flex;
    gap: 14px;
    align-items: center;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 12px;
    transition: border-color .2s ease, transform .2s ease;
  }
  .credit-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .credit-card img {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: 10px;
    flex: 0 0 auto;
    background: var(--border);
  }
  .credit-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .credit-no { font-size: .72rem; letter-spacing: .12em; color: var(--muted); font-weight: 700; }
  .credit-link {
    font-weight: 600;
    color: var(--heading);
    text-decoration: none;
    font-size: .92rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .credit-link:hover { color: var(--accent); text-decoration: underline; }
  .credit-tags { font-size: .74rem; color: var(--muted); }
</style>
