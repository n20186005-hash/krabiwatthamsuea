---
import { getI18n } from '../i18n/ui';

const { messages } = getI18n(Astro.url);
const b = messages.bestTime;
---

<section class="section-padding" id="best-time">
  <div class="container">
    <span class="eyebrow">{b.eyebrow}</span>
    <h2 class="section-title">{b.title}</h2>
    <p class="section-lead">{b.subtitle}</p>

    <h3 class="group-title">{b.dayTitle}</h3>
    <div class="bt-grid">
      {b.day.map((d: any) => (
        <div class="card card-pad bt fade-up">
          <div class="bt-head">
            <span class="bt-label">{d.label}</span>
            <span class={`bt-badge ${d.tone}`}>{d.score}</span>
          </div>
          <p class="bt-text">{d.text}</p>
        </div>
      ))}
    </div>

    <h3 class="group-title" style="margin-top:34px">{b.seasonTitle}</h3>
    <div class="bt-grid">
      {b.season.map((d: any) => (
        <div class="card card-pad bt fade-up">
          <div class="bt-head">
            <span class="bt-label">{d.label}</span>
            <span class={`bt-badge ${d.tone}`}>{d.score}</span>
          </div>
          <p class="bt-text">{d.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .group-title { font-size: 1.2rem; margin: 28px 0 16px; color: var(--heading); }
  .bt-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 18px; }
  .bt-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
  .bt-label { font-weight: 700; color: var(--heading); font-size: 1.02rem; }
  .bt-badge { font-family: var(--font-body); font-size: 0.78rem; font-weight: 700; padding: 4px 12px; border-radius: 999px; white-space: nowrap; }
  .bt-badge.best { background: var(--green-soft); color: var(--green); }
  .bt-badge.warm { background: var(--accent-soft); color: var(--accent-strong); }
  .bt-badge.cool { background: var(--surface-2); color: var(--text-muted); }
  .bt-text { margin: 0; color: var(--text-muted); font-size: 0.95rem; }
</style>
