---
import { getLangFromUrl, getI18n } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const { messages } = getI18n(Astro.url);
const f = messages.footer;

const navLinks = [
  { href: '#overview', label: messages.header.overview },
  { href: '#visit', label: messages.header.visit },
  { href: '#transport', label: messages.header.transport },
  { href: '#history', label: messages.header.history },
  { href: '#gallery', label: messages.header.gallery },
  { href: '#reviews', label: messages.header.reviews },
  { href: '#faq', label: messages.header.faq },
];
---

<footer class="site-footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <a class="brand" href={`/${lang}`}>
        <span class="brand-mark">วัด</span>
        <span class="brand-text">{f.siteName}</span>
      </a>
      <p class="footer-tag">{f.tagline}</p>
      <div class="mission-block footer-mission">
        <p class="mission-title">{f.missionTitle}</p>
        <p class="mission-text" style="white-space: pre-wrap;">{f.missionText}</p>
      </div>
    </div>

    <div class="footer-col">
      <h4>{f.exploreTitle}</h4>
      <ul>
        {navLinks.map((l) => <li><a href={`/${lang}${l.href}`}>{l.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{f.resourcesTitle}</h4>
      <ul>
        {f.resources.map((r: any) => (
          <li><a href={r.url} target="_blank" rel="noopener">{r.name}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col footer-map">
      <h4>{f.visitTitle}</h4>
      <p class="footer-addr">{f.addressValue}</p>
      <p class="footer-hours">{f.hoursValue}</p>
      <a class="footer-maps" href={f.mapsUrl} target="_blank" rel="noopener">
        {f.mapsLabel}
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} {f.siteName}. {f.rights}</p>
    <p class="footer-disclaimer">{f.disclaimer}</p>
  </div>
</footer>

<style>
  .site-footer { background: var(--surface-2); border-top: 1px solid var(--border); margin-top: 40px; }
  .footer-top { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 30px; padding-block: 48px 30px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; }
  .brand-mark { display: grid; place-items: center; width: 36px; height: 36px; border-radius: 10px; background: var(--accent); color: #fff; font-family: var(--font-display); }
  .brand-text { font-family: var(--font-display); font-size: 1.15rem; color: var(--heading); font-weight: 700; }
  .footer-tag { color: var(--text-muted); margin: 14px 0 16px; max-width: 360px; }
  .footer-mission { margin-top: 0; }
  .footer-col h4 { font-family: var(--font-body); font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-strong); margin: 0 0 14px; }
  .footer-col ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
  .footer-col a { color: var(--text); font-weight: 600; }
  .footer-col a:hover { color: var(--accent-strong); }
  .footer-addr, .footer-hours { color: var(--text-muted); margin: 0 0 8px; font-size: 0.95rem; }
  .footer-maps { display: inline-flex; align-items: center; gap: 8px; margin-top: 6px; padding: 11px 18px; border-radius: 999px; background: var(--accent); color: #fff; font-weight: 700; transition: background 0.2s ease; }
  .footer-maps:hover { background: var(--accent-strong); }
  .footer-bottom { border-top: 1px solid var(--border); padding-block: 20px; color: var(--text-muted); font-size: 0.85rem; }
  .footer-bottom p { margin: 0; }
  .footer-disclaimer { margin-top: 6px; }
  @media (max-width: 880px) { .footer-top { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .footer-top { grid-template-columns: 1fr; } }
</style>
